#!/bin/bash

# FNNet Monitor - fnOS Application Lifecycle Script
APP_NAME="fnnet-monitor"
APP_DIR="/var/apps/${APP_NAME}"
APP_DATA="/var/apps/${APP_NAME}/data"
APP_VENV="${APP_DATA}/venv"
APP_PY="${APP_DIR}/app/app.py"
PID_FILE="${APP_DATA}/fnnet-monitor.pid"
LOG_FILE="${APP_DATA}/fnnet-monitor.log"
SERVICE_PORT=5000

print_status() { echo -e "\033[0;32m[INFO]\033[0m $1"; }
print_warn() { echo -e "\033[1;33m[WARN]\033[0m $1"; }
print_error() { echo -e "\033[0;31m[ERROR]\033[0m $1"; }

is_running() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then return 0; fi
        rm -f "$PID_FILE"
    fi
    return 1
}

start_app() {
    print_status "Starting FNNet Monitor..."
    if is_running; then print_warn "Already running (PID: $(cat $PID_FILE))"; return 0; fi
    mkdir -p "$APP_DATA"
    if [ ! -d "$APP_VENV" ]; then install_deps; fi
    cd "$APP_DIR/app"
    source "$APP_VENV/bin/activate"
    nohup python3 "$APP_PY" > "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    sleep 2
    if kill -0 "$(cat $PID_FILE)" 2>/dev/null; then
        print_status "Started (PID: $(cat $PID_FILE)) at http://localhost:${SERVICE_PORT}"
    else
        print_error "Failed to start"; rm -f "$PID_FILE"; return 1
    fi
}

stop_app() {
    print_status "Stopping FNNet Monitor..."
    if ! is_running; then print_warn "Not running"; return 0; fi
    local pid=$(cat "$PID_FILE")
    kill "$pid" 2>/dev/null
    local i=0; while kill -0 "$pid" 2>/dev/null && [ $i -lt 10 ]; do sleep 1; i=$((i+1)); done
    if kill -0 "$pid" 2>/dev/null; then kill -9 "$pid" 2>/dev/null; fi
    rm -f "$PID_FILE"
    print_status "Stopped"
}

show_status() {
    if is_running; then
        local pid=$(cat "$PID_FILE")
        print_status "Running (PID: $pid) on port ${SERVICE_PORT}"
    else
        print_warn "Not running"
    fi
}

install_deps() {
    print_status "Installing dependencies..."
    python3 -m venv "$APP_VENV"
    source "$APP_VENV/bin/activate"
    pip install --upgrade pip -q
    pip install -r "$APP_DIR/app/requirements.txt" -q
    print_status "Dependencies installed"
}

case "$1" in
    start) start_app ;;
    stop) stop_app ;;
    restart) stop_app; sleep 1; start_app ;;
    status) show_status ;;
    install) install_deps ;;
    *) echo "Usage: $0 {start|stop|restart|status|install}"; exit 1 ;;
esac
exit $?
